{% extends 'base.html.twig' %}

{% block title %}Conversation avec {{ correspondant.prenom }} {{ correspondant.nom }}{% endblock %}

{% block body %}
<div class="bo-layout">

    <aside class="bo-sidebar">
        <div class="bo-brand">
            <span class="bo-brand-icon">⬡</span>
            <span class="bo-brand-name">Admin - TTJ</span>
        </div>
        <nav class="bo-nav">
            <a href="{{ path('admin_dashboard') }}" class="bo-nav-link">
                <span class="bo-nav-icon">▣</span> Tableau de bord
            </a>
            <a href="{{ path('admin_users') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◈</span> Utilisateurs
            </a>
            <a href="{{ path('admin_pending_registrations') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◎</span> Inscriptions
            </a>
            <a href="{{ path('admin_pending_offers') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◇</span> Offres
            </a>
            <a href="{{ path('message_index') }}" class="bo-nav-link active">
                <span class="bo-nav-icon">✉</span> Messagerie
            </a>
        </nav>
        <a href="{{ path('admin_logout') }}" class="bo-logout">
            <span>⏻</span> Déconnexion
        </a>
    </aside>

    <main class="bo-main">
        <header class="bo-header">
            <div style="display:flex; align-items:center; gap:14px;">
                <div style="
                    width:44px; height:44px; border-radius:50%;
                    background:#dbeafe; color:#1d4ed8;
                    display:flex; align-items:center; justify-content:center;
                    font-weight:600; font-size:14px; flex-shrink:0;
                    font-family:var(--bo-mono);
                ">
                    {{ correspondant.prenom|first|upper }}{{ correspondant.nom|first|upper }}
                </div>
                <div>
                    <h1 class="bo-page-title">{{ correspondant.prenom }} {{ correspondant.nom }}</h1>
                    <p class="bo-page-sub">{{ correspondant.email }}</p>
                </div>
            </div>
            <div style="display:flex; gap:8px;">
                <a href="{{ path('message_index') }}"
                   class="bo-btn" style="background:#f1f5f9; color:#374151;">
                    Retour
                </a>
            </div>
        </header>

        <div class="bo-card" style="max-width:760px;">

            {% if messages is empty %}
                <div class="bo-empty">Aucun message dans cette conversation.</div>
            {% else %}
                <div style="padding:20px; display:flex; flex-direction:column; gap:14px;">
                    {% for message in messages %}
                        {% set isSent = message.emetteur.nom ~ message.emetteur.prenom != correspondant.nom ~ correspondant.prenom %}
                        <div style="display:flex; flex-direction:column; align-items:{{ isSent ? 'flex-end' : 'flex-start' }};">

                            <div style="
                                max-width:68%;
                                background:{{ isSent ? '#dbeafe' : '#f1f5f9' }};
                                color:{{ isSent ? '#1e40af' : '#1a1d23' }};
                                border-radius:12px;
                                border-bottom-{{ isSent ? 'right' : 'left' }}-radius:4px;
                                padding:10px 14px;
                                font-size:13.5px;
                                line-height:1.6;
                            ">
                                {{ message.contenu }}
                            </div>

                            <div style="display:flex; align-items:center; gap:6px; margin-top:4px;">
                                <span style="font-size:11.5px; color:var(--bo-muted);">
                                    {{ message.dateEnvoi }}
                                </span>
                                <span class="bo-badge {{ isSent ? 'bo-badge--blue' : 'bo-badge--green' }}">
                                    {{ isSent ? 'Envoyé' : 'Reçu' }}
                                </span>
                                <a href="{{ path(isSent ? 'message_sent_show' : 'message_received_show', { id: message.id }) }}"
                                   style="font-size:11.5px; color:var(--bo-accent); text-decoration:none;">
                                    Détail
                                </a>
                            </div>

                        </div>
                    {% endfor %}
                </div>

                <div style="padding:16px 20px; border-top:1px solid var(--bo-border);">
                    <form action="{{ path('message_send', { destinataireId: correspondantId }) }}" method="post"
                          style="display:flex; gap:10px; align-items:flex-end;">
                        <div style="flex:1;">
                            <textarea name="contenu" rows="2" placeholder="Écrire un message…" required
                                      style="
                                          width:100%; padding:9px 12px;
                                          border:1px solid var(--bo-border); border-radius:6px;
                                          font-size:13.5px; font-family:var(--bo-font);
                                          color:var(--bo-text); background:#fff; resize:none; outline:none;
                                      "></textarea>
                        </div>
                        <button type="submit" class="bo-btn bo-btn--blue">Envoyer</button>
                    </form>
                </div>
            {% endif %}

        </div>
    </main>

</div>
{% endblock %}
