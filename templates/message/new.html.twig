{% extends 'base.html.twig' %}

{% block title %}Nouveau message{% endblock %}

{% block body %}
<div class="bo-layout">

    <aside class="bo-sidebar">
        <div class="bo-brand">
            <span class="bo-brand-icon">⬡</span>
            <span class="bo-brand-name">Admin</span>
        </div>
        <nav class="bo-nav">
            <a href="{{ path('admin_dashboard') }}" class="bo-nav-link">
                <span class="bo-nav-icon">▣</span> Tableau de bord
            </a>
            <a href="{{ path('admin_users') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◈</span> Utilisateurs
            </a>
            <a href="{{ path('admin_pending_registrations') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◎</span> Inscriptions
            </a>
            <a href="{{ path('admin_pending_offers') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◇</span> Offres
            </a>
            <a href="{{ path('message_index') }}" class="bo-nav-link active">
                <span class="bo-nav-icon">✉</span> Messagerie
            </a>
        </nav>
        <a href="{{ path('admin_logout') }}" class="bo-logout">
            <span>⏻</span> Déconnexion
        </a>
    </aside>

    <main class="bo-main">
        <header class="bo-header">
            <div>
                <h1 class="bo-page-title">Nouveau message</h1>
                <p class="bo-page-sub">Sélectionnez un destinataire puis rédigez votre message</p>
            </div>
            <a href="{{ path('message_index') }}"
               class="bo-btn" style="background:#f1f5f9; color:#374151;">
                Retour
            </a>
        </header>

        {% if error %}
            <div style="padding:12px 20px; background:#fef2f2; color:#b91c1c;
                        border:1px solid #fecaca; border-radius:8px; font-size:13.5px; margin-bottom:20px;">
                {{ error }}
            </div>
        {% endif %}

        {# Formulaire — action dynamique via JS, destinataireId dans l'URL #}
        <form id="send-form"
              method="post"
              style="display:flex; flex-direction:column; gap:20px; max-width:680px;">

            {# Champ caché pour l'id du destinataire sélectionné #}
            <input type="hidden" name="_destinataire_id" id="selected-id" value="{{ preselectedId ?? '' }}">

            {# Sélecteur de destinataire #}
            <div class="bo-card">
                <div class="bo-card-head">
                    <span class="bo-card-title">Destinataire</span>
                    <span id="selected-label" style="font-size:12.5px; color:var(--bo-muted);">
                        {% if preselectedId %}
                            1 sélectionné
                        {% else %}
                            Aucun sélectionné
                        {% endif %}
                    </span>
                </div>

                {# Filtre de recherche #}
                <div style="padding:10px 16px; border-bottom:1px solid var(--bo-border);">
                    <input type="text"
                           id="search-users"
                           placeholder="Rechercher par nom, prénom ou email…"
                           oninput="filterUsers(this.value)"
                           style="width:100%; padding:7px 12px; border:1px solid var(--bo-border);
                                  border-radius:6px; font-size:13px; font-family:var(--bo-font);
                                  color:var(--bo-text); background:#fff; outline:none;">
                </div>

                <div id="user-list" style="max-height:320px; overflow-y:auto;">
                    {% if users is empty %}
                        <div class="bo-empty">Aucun utilisateur disponible.</div>
                    {% else %}
                        {% for user in users %}
                        <div class="user-item"
                             data-id="{{ user.id }}"
                             data-name="{{ user.prenom|lower }} {{ user.nom|lower }} {{ user.email|lower }}"
                             onclick="selectUser({{ user.id }}, '{{ user.prenom }} {{ user.nom }}')"
                             style="
                                 display:flex; align-items:center; gap:12px;
                                 padding:11px 16px; cursor:pointer;
                                 border-bottom:1px solid #f0f1f3;
                                 transition:background .12s;
                                 {% if preselectedId == user.id %}background:#eff6ff;{% endif %}
                             ">

                            {# Indicateur de sélection #}
                            <div class="user-check" style="
                                width:16px; height:16px; border-radius:50%; flex-shrink:0;
                                border:2px solid var(--bo-border);
                                background:{{ preselectedId == user.id ? '#2563eb' : 'transparent' }};
                                border-color:{{ preselectedId == user.id ? '#2563eb' : 'var(--bo-border)' }};
                                transition:all .12s;
                            "></div>

                            {# Avatar initiales #}
                            <div style="
                                width:36px; height:36px; border-radius:50%; flex-shrink:0;
                                background:#dbeafe; color:#1d4ed8;
                                display:flex; align-items:center; justify-content:center;
                                font-size:12px; font-weight:600; font-family:var(--bo-mono);
                            ">
                                {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                            </div>

                            {# Infos textuelles #}
                            <div style="flex:1; min-width:0;">
                                <div style="font-weight:500; font-size:13.5px; color:var(--bo-text);">
                                    {{ user.prenom }} {{ user.nom }}
                                </div>
                                <div style="font-size:12px; color:var(--bo-muted); margin-top:1px;
                                            white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                    {{ user.email }}
                                </div>
                            </div>

                            {# ID chip #}
                            <span style="
                                font-size:11px; font-family:var(--bo-mono);
                                background:#f1f5f9; color:#6b7280;
                                padding:2px 8px; border-radius:5px; flex-shrink:0;
                            ">#{{ user.id }}</span>

                        </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>

            {# Contenu du message #}
            <div class="bo-card">
                <div class="bo-card-head">
                    <span class="bo-card-title">Message</span>
                </div>
                <div style="padding:16px 20px;">
                    <textarea name="contenu" rows="5"
                              placeholder="Rédigez votre message ici…"
                              required
                              style="
                                  width:100%; padding:10px 14px;
                                  border:1px solid var(--bo-border);
                                  border-radius:6px; font-size:13.5px;
                                  font-family:var(--bo-font); color:var(--bo-text);
                                  background:#fff; outline:none; resize:vertical;
                                  line-height:1.6;
                              ">{{ prefillContent ?? '' }}</textarea>
                </div>
            </div>

            <div style="display:flex; gap:8px;">
                <button type="submit" id="submit-btn" class="bo-btn bo-btn--blue"
                        {% if not preselectedId %}disabled style="opacity:.5; cursor:not-allowed;"{% endif %}>
                    Envoyer le message
                </button>
                <a href="{{ path('message_index') }}"
                   class="bo-btn" style="background:#f1f5f9; color:#374151;">
                    Annuler
                </a>
            </div>

        </form>
    </main>

</div>

<script>
(function () {
    var selectedId = {{ preselectedId ?? 'null' }};

    window.selectUser = function (id, label) {
        selectedId = id;

        document.getElementById('selected-id').value = id;
        document.getElementById('selected-label').textContent = label + ' sélectionné(e)';

        var btn = document.getElementById('submit-btn');
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.style.cursor = 'pointer';

        document.querySelectorAll('.user-item').forEach(function (item) {
            var isSelected = parseInt(item.dataset.id) === id;
            item.style.background = isSelected ? '#eff6ff' : '';
            var check = item.querySelector('.user-check');
            check.style.background = isSelected ? '#2563eb' : 'transparent';
            check.style.borderColor = isSelected ? '#2563eb' : 'var(--bo-border)';
        });

        var form = document.getElementById('send-form');
        form.action = '/admin/messages/send/' + id;
    };

    window.filterUsers = function (query) {
        var q = query.toLowerCase().trim();
        document.querySelectorAll('.user-item').forEach(function (item) {
            var match = !q || item.dataset.name.indexOf(q) !== -1;
            item.style.display = match ? '' : 'none';
        });
    };

    {% if preselectedId %}
    (function () {
        var form = document.getElementById('send-form');
        form.action = '/admin/messages/send/' + selectedId;
    })();
    {% endif %}
})();
</script>

{% endblock %}
