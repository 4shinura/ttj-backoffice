{% extends 'base.html.twig' %}

{% block title %}Admin — Voir utilisateur{% endblock %}

{% block body %}
<div class="bo-layout">

    <aside class="bo-sidebar">
        <div class="bo-brand">
            <span class="bo-brand-icon">⬡</span>
            <span class="bo-brand-name">Admin</span>
        </div>
        <nav class="bo-nav">
            <a href="{{ path('admin_dashboard') }}" class="bo-nav-link">
                <span class="bo-nav-icon">▣</span> Tableau de bord
            </a>
            <a href="{{ path('admin_users') }}" class="bo-nav-link active">
                <span class="bo-nav-icon">◈</span> Utilisateurs
            </a>
            <a href="{{ path('admin_pending_registrations') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◎</span> Inscriptions
            </a>
            <a href="{{ path('admin_pending_offers') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◇</span> Offres
            </a>
            <a href="{{ path('message_index') }}" class="bo-nav-link">
                <span class="bo-nav-icon">✉</span> Messagerie
            </a>
        </nav>
        <a href="{{ path('admin_logout') }}" class="bo-logout">
            <span>⏻</span> Déconnexion
        </a>
    </aside>

    <main class="bo-main">
        <header class="bo-header">
            <div>
                <h1 class="bo-page-title">Détail de l'utilisateur</h1>
                <p class="bo-page-sub">{{ user.nom }} {{ user.prenom }}</p>
            </div>
            <div style="display:flex; gap:8px;">
                <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="bo-btn bo-btn--blue">Modifier</a>
                <a href="{{ path('admin_users') }}" class="bo-btn" style="background:#f1f5f9; color:#374151;">Retour</a>
            </div>
        </header>

        <div class="bo-card">
            <table class="bo-table bo-table--full">
                <tbody>
                    <tr>
                        <td class="bo-muted" style="width:160px;">#</td>
                        <td class="bo-id">{{ user.id }}</td>
                    </tr>
                    <tr>
                        <td class="bo-muted">Nom</td>
                        <td><strong>{{ user.nom }}</strong></td>
                    </tr>
                    <tr>
                        <td class="bo-muted">Prénom</td>
                        <td>{{ user.prenom }}</td>
                    </tr>
                    <tr>
                        <td class="bo-muted">Email</td>
                        <td class="bo-muted">{{ user.email }}</td>
                    </tr>
                    <tr>
                        <td class="bo-muted">Type</td>
                        <td><span class="bo-badge bo-badge--blue">{{ user.type }}</span></td>
                    </tr>
                    <tr>
                        <td class="bo-muted">Statut</td>
                        <td>
                            <span class="bo-badge {{ user.statut == 'actif' ? 'bo-badge--green' : 'bo-badge--red' }}">
                                {{ user.statut }}
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>

            <div style="padding:16px 20px; border-top:1px solid var(--bo-border);">
                <form action="{{ path('admin_user_delete', {id: user.id}) }}" method="post"
                      onsubmit="return confirm('Supprimer cet utilisateur ?');">
                    <button type="submit" class="bo-btn bo-btn--red">Supprimer</button>
                </form>
            </div>
        </div>
    </main>
</div>
{% endblock %}