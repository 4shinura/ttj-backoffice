{% extends 'base.html.twig' %}

{% block title %}Admin — Utilisateurs{% endblock %}

{% block body %}
<div class="bo-layout">

    <aside class="bo-sidebar">
        <div class="bo-brand">
            <span class="bo-brand-icon">⬡</span>
            <span class="bo-brand-name">Admin</span>
        </div>
        <nav class="bo-nav">
            <a href="{{ path('admin_dashboard') }}" class="bo-nav-link">
                <span class="bo-nav-icon">▣</span> Tableau de bord
            </a>
            <a href="{{ path('admin_users') }}" class="bo-nav-link active">
                <span class="bo-nav-icon">◈</span> Utilisateurs
            </a>
            <a href="{{ path('admin_pending_registrations') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◎</span> Inscriptions
            </a>
            <a href="{{ path('admin_pending_offers') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◇</span> Offres
            </a>
            <a href="{{ path('message_index') }}" class="bo-nav-link">
                <span class="bo-nav-icon">✉</span> Messagerie
            </a>
        </nav>
        <a href="{{ path('admin_logout') }}" class="bo-logout">
            <span>⏻</span> Déconnexion
        </a>
    </aside>

    <main class="bo-main">
        <header class="bo-header">
            <div>
                <h1 class="bo-page-title">Utilisateurs</h1>
                <p class="bo-page-sub">{{ users|length }} compte(s) enregistré(s)</p>
            </div>
            <a href="{{ path('admin_user_new') }}" class="bo-btn bo-btn--blue">Ajouter un utilisateur</a>
        </header>

        <div class="bo-card">
            {% if users is not empty %}
            <table class="bo-table bo-table--full">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Email</th>
                        <th>Type</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td class="bo-id">{{ user.id }}</td>
                        <td><strong>{{ user.nom }}</strong></td>
                        <td>{{ user.prenom }}</td>
                        <td class="bo-muted">{{ user.email }}</td>
                        <td><span class="bo-badge bo-badge--blue">{{ user.type }}</span></td>
                        <td>
                            <span class="bo-badge {{ user.statut == 'actif' ? 'bo-badge--green' : 'bo-badge--red' }}">
                                {{ user.statut }}
                            </span>
                        </td>
                        <td>
                            <div style="display:flex; align-items:center; gap:6px;">
                                <a href="{{ path('admin_user_show', {id: user.id}) }}" class="bo-btn bo-btn--blue">Voir</a>
                                <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="bo-btn" style="background:#f1f5f9; color:#374151;">Modifier</a>
                                <form action="{{ path('admin_user_delete', {id: user.id}) }}" method="post" style="display:inline">
                                    <button type="submit" class="bo-btn bo-btn--red"
                                            onclick="return confirm('Supprimer cet utilisateur ?');">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="bo-empty">Aucun utilisateur trouvé</div>
            {% endif %}
        </div>
    </main>
</div>
{% endblock %}