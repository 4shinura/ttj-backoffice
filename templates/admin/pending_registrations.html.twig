{% extends 'base.html.twig' %}

{% block title %}Admin — Inscriptions en attente{% endblock %}

{% block body %}
<div class="bo-layout">

    <aside class="bo-sidebar">
        <div class="bo-brand">
            <span class="bo-brand-icon">⬡</span>
            <span class="bo-brand-name">Admin - TTJ</span>
        </div>
        <nav class="bo-nav">
            <a href="{{ path('admin_dashboard') }}" class="bo-nav-link">
                <span class="bo-nav-icon">▣</span> Tableau de bord
            </a>
            <a href="{{ path('admin_users') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◈</span> Utilisateurs
            </a>
            <a href="{{ path('admin_pending_registrations') }}" class="bo-nav-link active">
                <span class="bo-nav-icon">◎</span> Inscriptions
            </a>
            <a href="{{ path('admin_pending_offers') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◇</span> Offres
            </a>
            <a href="{{ path('message_index') }}" class="bo-nav-link">
                <span class="bo-nav-icon">✉</span> Messagerie
            </a>
        </nav>
        <a href="{{ path('admin_logout') }}" class="bo-logout">
            <span>⏻</span> Déconnexion
        </a>
    </aside>

    <main class="bo-main">
        <header class="bo-header">
            <div>
                <h1 class="bo-page-title">Inscriptions en attente</h1>
                <p class="bo-page-sub">{{ pendingUsers|length }} compte(s) à valider</p>
            </div>
        </header>

        <div class="bo-card">
            {% if pendingUsers is not empty %}
            <table class="bo-table bo-table--full">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Email</th>
                        <th>Type</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in pendingUsers %}
                    <tr>
                        <td class="bo-id">{{ user.id }}</td>
                        <td><strong>{{ user.nom }}</strong></td>
                        <td>{{ user.prenom }}</td>
                        <td class="bo-muted">{{ user.email }}</td>
                        <td><span class="bo-badge bo-badge--blue">{{ user.type }}</span></td>
                        <td>
                            <form method="post" action="{{ path('admin_validate_registration', {id: user.id}) }}">
                                <button type="submit" class="bo-btn bo-btn--green">Valider</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="bo-empty">Aucune inscription en attente de validation</div>
            {% endif %}
        </div>
    </main>
</div>
{% endblock %}
