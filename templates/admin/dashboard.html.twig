{% extends 'base.html.twig' %}

{% block title %}Admin — Tableau de bord{% endblock %}

{% block body %}
<div class="bo-layout">

    {# Sidebar #}
    <aside class="bo-sidebar">
        <div class="bo-brand">
            <span class="bo-brand-icon">⬡</span>
            <span class="bo-brand-name">Admin</span>
        </div>
        <nav class="bo-nav">
            <a href="{{ path('admin_dashboard') }}" class="bo-nav-link active">
                <span class="bo-nav-icon">▣</span> Tableau de bord
            </a>
            <a href="{{ path('admin_users') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◈</span> Utilisateurs
            </a>
            <a href="{{ path('admin_pending_registrations') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◎</span> Inscriptions
            </a>
            <a href="{{ path('admin_pending_offers') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◇</span> Offres
            </a>
            <a href="{{ path('message_index') }}" class="bo-nav-link active">
                <span class="bo-nav-icon">✉</span> Messagerie
            </a>
        </nav>
        <a href="{{ path('admin_logout') }}" class="bo-logout">
            <span>⏻</span> Déconnexion
        </a>
    </aside>

    {# Main #}
    <main class="bo-main">
        <header class="bo-header">
            <div>
                <h1 class="bo-page-title">Tableau de bord</h1>
                <p class="bo-page-sub">Vue d'ensemble de l'activité</p>
            </div>
        </header>

        {# Stats #}
        <div class="bo-stats">
            <div class="bo-stat bo-stat--blue">
                <div class="bo-stat-label">Utilisateurs</div>
                <div class="bo-stat-value">—</div>
            </div>
            <div class="bo-stat bo-stat--amber">
                <div class="bo-stat-label">Inscriptions en attente</div>
                <div class="bo-stat-value">{{ pendingUsers|length }}</div>
            </div>
            <div class="bo-stat bo-stat--green">
                <div class="bo-stat-label">Offres en attente</div>
                <div class="bo-stat-value">{{ pendingOffers|length }}</div>
            </div>
        </div>

        {# Tables #}
        <div class="bo-grid-2">

            <div class="bo-card">
                <div class="bo-card-head">
                    <h2 class="bo-card-title">Inscriptions en attente</h2>
                    <a href="{{ path('admin_pending_registrations') }}" class="bo-link-more">Voir tout →</a>
                </div>
                {% if pendingUsers is not empty %}
                <table class="bo-table">
                    <thead>
                        <tr>
                            <th>#</th><th>Nom</th><th>Email</th><th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in pendingUsers|slice(0, 5) %}
                        <tr>
                            <td class="bo-id">{{ user.id }}</td>
                            <td><strong>{{ user.prenom }} {{ user.nom }}</strong></td>
                            <td class="bo-muted">{{ user.email }}</td>
                            <td><span class="bo-badge bo-badge--blue">{{ user.type }}</span></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                {% else %}
                <div class="bo-empty">Aucune inscription en attente</div>
                {% endif %}
            </div>

            <div class="bo-card">
                <div class="bo-card-head">
                    <h2 class="bo-card-title">Offres en attente</h2>
                    <a href="{{ path('admin_pending_offers') }}" class="bo-link-more">Voir tout →</a>
                </div>
                {% if pendingOffers is not empty %}
                <table class="bo-table">
                    <thead>
                        <tr>
                            <th>#</th><th>Titre</th><th>Type</th><th>Date limite</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for offer in pendingOffers|slice(0, 5) %}
                        <tr>
                            <td class="bo-id">{{ offer.id }}</td>
                            <td><strong>{{ offer.titre|default('—') }}</strong></td>
                            <td><span class="bo-badge bo-badge--green">{{ offer.type }}</span></td>
                            <td class="bo-muted">{{ offer.dateLimite|default('—') }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                {% else %}
                <div class="bo-empty">Aucune offre en attente</div>
                {% endif %}
            </div>

        </div>
    </main>
</div>
{% endblock %}
