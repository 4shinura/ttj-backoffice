{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}
<div class="min-h-screen bg-cover bg-center" style="background-image: url('/images/admin-dashboard-bg.png');">
    <div class="bg-white/75 backdrop-blur-sm min-h-screen">
        <div class="container mx-auto py-8 px-4">
            <div class="flex justify-between items-center mb-6">
                <div>
                    <h1 class="text-3xl md:text-4xl font-extrabold text-slate-800">Tableau de bord administrateur</h1>
                    <p class="text-sm text-slate-600 mt-1">Contrôle des inscriptions et de la publication des offres</p>
                </div>
                <a href="{{ path('admin_logout') }}" class="inline-flex items-center gap-2 bg-red-600 text-white px-4 py-2 rounded-lg shadow hover:bg-red-700">
                    Déconnexion
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <a href="{{ path('admin_users') }}" class="p-4 bg-white rounded-2xl shadow-lg border border-slate-200 hover:shadow-xl transition">
                    <h2 class="text-lg font-semibold text-blue-600">Utilisateurs</h2>
                    <p class="mt-1 text-sm text-slate-500">Voir et gérer les utilisateurs</p>
                </a>

                <a href="{{ path('admin_pending_registrations') }}" class="p-4 bg-white rounded-2xl shadow-lg border border-slate-200 hover:shadow-xl transition">
                    <h2 class="text-lg font-semibold text-amber-600">Inscriptions en attente</h2>
                    <p class="mt-1 text-sm text-slate-500">Valider les nouveaux comptes</p>
                </a>

                <a href="{{ path('admin_pending_offers') }}" class="p-4 bg-white rounded-2xl shadow-lg border border-slate-200 hover:shadow-xl transition">
                    <h2 class="text-lg font-semibold text-emerald-600">Offres en attente</h2>
                    <p class="mt-1 text-sm text-slate-500">Publier les offres validées</p>
                </a>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                <div class="bg-white p-5 rounded-2xl shadow-xl border border-slate-200">
                    <h3 class="font-semibold text-slate-800 mb-3">Inscriptions en attente de validation</h3>
                    {% if pendingUsers is not empty %}
                        <ul class="space-y-2 max-h-60 overflow-auto">
                            {% for user in pendingUsers %}
                                <li class="p-2 rounded-lg bg-slate-50 border border-slate-200">
                                    <div class="flex items-center justify-between text-sm">
                                        <span class="font-medium">{{ user.nom }} {{ user.prenom }} ({{ user.type }})</span>
                                        <span class="text-slate-500">#{{ user.id }}</span>
                                    </div>
                                    <div class="text-xs text-slate-500">{{ user.email }} • {{ user.statut }}</div>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <div class="h-48 bg-slate-100 rounded-lg border border-dashed border-slate-300 flex items-center justify-center text-slate-400">Aucune inscription en attente</div>
                    {% endif %}
                </div>

                <div class="bg-white p-5 rounded-2xl shadow-xl border border-slate-200">
                    <h3 class="font-semibold text-slate-800 mb-3">Candidatures en attente de validation</h3>
                    {% if pendingOffers is not empty %}
                        <ul class="space-y-2 max-h-60 overflow-auto">
                            {% for offer in pendingOffers %}
                                <li class="p-2 rounded-lg bg-slate-50 border border-slate-200">
                                    <div class="flex items-center justify-between text-sm">
                                        <span class="font-medium">{{ offer.titre|default('Titre inconnu') }}</span>
                                        <span class="text-slate-500">#{{ offer.id }}</span>
                                    </div>
                                    <div class="text-xs text-slate-500">{{ offer.type }} • {{ offer.datePublication|default('-') }}</div>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <div class="h-48 bg-slate-100 rounded-lg border border-dashed border-slate-300 flex items-center justify-center text-slate-400">Aucune candidature en attente</div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}