{% extends 'base.html.twig' %}

{% block title %}Admin — Offres en attente{% endblock %}

{% block body %}
<div class="bo-layout">

    <aside class="bo-sidebar">
        <div class="bo-brand">
            <span class="bo-brand-icon">⬡</span>
            <span class="bo-brand-name">Admin</span>
        </div>
        <nav class="bo-nav">
            <a href="{{ path('admin_dashboard') }}" class="bo-nav-link">
                <span class="bo-nav-icon">▣</span> Tableau de bord
            </a>
            <a href="{{ path('admin_users') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◈</span> Utilisateurs
            </a>
            <a href="{{ path('admin_pending_registrations') }}" class="bo-nav-link">
                <span class="bo-nav-icon">◎</span> Inscriptions
            </a>
            <a href="{{ path('admin_pending_offers') }}" class="bo-nav-link active">
                <span class="bo-nav-icon">◇</span> Offres
            </a>
        </nav>
        <a href="{{ path('admin_logout') }}" class="bo-logout">
            <span>⏻</span> Déconnexion
        </a>
    </aside>

    <main class="bo-main">
        <header class="bo-header">
            <div>
                <h1 class="bo-page-title">Offres en attente</h1>
                <p class="bo-page-sub">{{ pendingOffers|length }} offre(s) à publier</p>
            </div>
        </header>

        <div class="bo-card">
            {% if pendingOffers is not empty %}
            <table class="bo-table bo-table--full">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Description</th>
                        <th>Publication</th>
                        <th>Date limite</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for offer in pendingOffers %}
                    <tr>
                        <td class="bo-id">{{ offer.id }}</td>
                        <td><strong>{{ offer.titre }}</strong></td>
                        <td><span class="bo-badge bo-badge--green">{{ offer.type }}</span></td>
                        <td class="bo-muted">{{ offer.description|slice(0, 60) }}…</td>
                        <td class="bo-muted">{{ offer.datePublication|default('—') }}</td>
                        <td class="bo-muted">{{ offer.dateLimite|default('—') }}</td>
                        <td>
                            <form method="post" action="{{ path('admin_publish_offer', {id: offer.id}) }}">
                                <button type="submit" class="bo-btn bo-btn--green">Publier</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="bo-empty">Aucune offre en attente de publication</div>
            {% endif %}
        </div>
    </main>
</div>
{% endblock %}
